---
import {
  Network,
  Cable,
  Camera,
  Monitor,
  Lightbulb,
  HelpCircle,
  Phone,
  MessageCircle,
  Mail,
  Instagram,
  Facebook,
  MapPin,
  Clock,
} from "lucide-astro";

const { name, size = 28 } = Astro.props;

const icons = {
  network: Network,
  cable: Cable,
  camera: Camera,
  computer: Monitor,
  consulting: Lightbulb,
  phone: Phone,
  message: MessageCircle,
  email: Mail,
  instagram: Instagram,
  facebook: Facebook,
  location: MapPin,
  clock: Clock,
};

const IconComponent = icons[name] ?? HelpCircle;
---

<IconComponent
  size={size}
  stroke-width={2}
  aria-hidden="true"
/>
