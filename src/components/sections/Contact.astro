---
import { site } from "../../config/site";
---

<section id="contact" class="contact-section">

  <div class="container">

    <div class="contact-card">

      <p class="eyebrow">
        Contact
      </p>

      <h2>
        Ready to Make Your Vehicle Shine?
      </h2>

      <p class="contact-description">
        Whether you're looking for a maintenance wash,
        premium detail, paint correction, or motorcycle
        detailing, we're here to help.
      </p>

      <div class="contact-grid">

        <div class="contact-item">
          <h3>Email</h3>

          <a href={`mailto:${site.contact.email}`}>
            {site.contact.email}
          </a>
        </div>

        <div class="contact-item">
          <h3>Instagram</h3>

          <a
            href="https://instagram.com/Emperial.Detailing"
            target="_blank"
            rel="noopener"
          >
            @Emperial.Detailing
          </a>
        </div>

        <div class="contact-item">
          <h3>Service Area</h3>

          <p>
            Central Florida
          </p>
        </div>

        <div class="contact-item">
          <h3>Availability</h3>

          <p>
            By Appointment Only
          </p>
        </div>

      </div>

      <a
        class="contact-button"
        href="mailto:shine@emperialdetailing.com"
      >
        Schedule Your Detail
      </a>

    </div>

  </div>

</section>
