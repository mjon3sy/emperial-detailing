---
import { paintCorrectionPackages } from "../../content/paintCorrection";
import { site } from "../../config/site";

const createBookingHref = (
  packageName: string,
  vehicle?: string,
  price?: string
) => {
  const subject = encodeURIComponent(
    `Booking Request - ${packageName}`
  );

  const packageDetails = vehicle
    ? `Package: ${packageName}
Vehicle size: ${vehicle}
Price shown: ${price}`
    : `Package: ${packageName}`;

  const body = encodeURIComponent(
`Hi Emperial Detailing,

I would like to book the following paint correction and protection package:

${packageDetails}

Name:
Phone:
Vehicle year, make, and model:
Vehicle color:
Paint condition or concerns:
Preferred date:
Service address:
Additional notes:

Thank you.`
  );

  return `mailto:${site.contact.email}?subject=${subject}&body=${body}`;
};
---

<section id="paint-correction" class="paint-correction-section">
  <div class="container">
    <div class="paint-correction-heading">
      <p class="eyebrow">Paint Correction & Protection</p>

      <h2>Restore Gloss. Reduce Imperfections. Protect the Finish.</h2>

      <p>
        Premium paint enhancement packages designed to improve your vehicle’s
        appearance while adding lasting ceramic protection.
      </p>
    </div>

    <div class="paint-correction-grid">
      {
        paintCorrectionPackages.map((pkg) => (
          <article
            class:list={[
              "paint-correction-card",
              { featured: pkg.featured },
            ]}
          >
            {pkg.featured && (
              <span class="paint-featured-badge">
                Enhanced Correction
              </span>
            )}

            <header class="paint-correction-card-header">
              <h3>{pkg.name}</h3>
              <p>{pkg.description}</p>
            </header>

            <div class="vehicle-prices">
              {pkg.prices.map((item) => (
                <div class="vehicle-price-option">
                  <strong>{item.price}</strong>
                  <span>{item.vehicle}</span>

                  <a
                    class="vehicle-book-link"
                    href={createBookingHref(
                      pkg.name,
                      item.vehicle,
                      item.price
                    )}
                  >
                    Book
                  </a>
                </div>
              ))}
            </div>

            <ul class="paint-feature-list">
              {pkg.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>

    <p class="pricing-note">
      Paint correction results and final pricing may vary based on paint
      condition, vehicle size, and the level of correction required.
    </p>
  </div>
</section>
