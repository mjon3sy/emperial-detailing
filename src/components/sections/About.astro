---
import { companyInfo } from "../../content/company";
---

<section id="about" class="about-section">
  <div class="container about-grid">

    <div class="about-content">

      <p class="eyebrow">About Emperial</p>

      <h2>{companyInfo.about.title}</h2>

      <p>
        {companyInfo.about.description}
      </p>

      <div class="highlight-grid">

        {
          companyInfo.highlights.map((item) => (
            <div class="highlight-card">
              ✓ {item}
            </div>
          ))
        }

      </div>

    </div>

    <div class="service-area">

      <p class="eyebrow">Service Area</p>

      <h3>We Come To You</h3>

      <p>
        Proudly serving customers throughout Central Florida.
      </p>

      <ul>
        {
          companyInfo.serviceArea.map((city) => (
            <li>{city}</li>
          ))
        }
      </ul>

      <p class="service-note">
        Outside our primary service area?
        Contact us—we may still be able to help.
      </p>

    </div>

  </div>
</section>
